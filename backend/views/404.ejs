<!doctype html>
<html lang="<%= lang %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="noindex,follow">
  <link rel="stylesheet" href="/css/tailwind.css">
  <link rel="stylesheet" href="/css/global.css">
</head>
<body class="bg-slate-100 text-slate-900">
  <main class="mx-auto max-w-3xl px-4 py-16">
    <p class="text-sm font-bold uppercase tracking-wide text-sky-700">DecMET</p>
    <h1 class="mt-3 text-3xl font-extrabold text-slate-950"><%= heading %></h1>
    <p class="mt-4 text-slate-700"><%= body %></p>
    <% if (icao) { %>
      <p class="mt-4 rounded border border-slate-300 bg-white p-4 font-mono text-sm">ICAO: <%= icao %></p>
    <% } %>
    <a class="mt-6 inline-flex rounded border border-sky-800 bg-sky-800 px-4 py-2 text-sm font-bold text-white" href="/">
      DecMET
    </a>
  </main>
</body>
</html>
