DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=your-mysql-user
DB_PASSWORD=your-mysql-password
DB_NAME=decmet_airports

# Example for Aiven MySQL:
# DB_HOST=mysql-example-project.aivencloud.com
# DB_PORT=28257
# DB_USER=avnadmin....
# DB_PASSWORD=your-aiven-password
# DB_NAME=decmet_airports

# =========================
# Server
# =========================
PORT=3000
NODE_ENV=development

# Front-end origin used mainly for local development with Live Server.
# In production, when Express serves the front-end and API from the same domain,
# this may not be necessary or can be adjusted according to the deployment.
FRONTEND_ORIGIN=http://127.0.0.1:5500

# =========================
# NOAA / AviationWeather API
# =========================
AVIATION_WEATHER_BASE_URL=https://aviationweather.gov/api/data
NOAA_REQUEST_TIMEOUT=10000

# User-Agent used when requesting NOAA/AviationWeather.
# Do not include sensitive information here.
NOAA_USER_AGENT=DecMET/1.0
AVIATION_WEATHER_USER_AGENT=DecMET/1.0

# =========================
# METAR Cache
# =========================
# Cache duration in seconds for each ICAO METAR request.
# Default recommended value: 60 seconds.
METAR_CACHE_TTL_SECONDS=60
